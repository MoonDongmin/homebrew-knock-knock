{
	"$schema": "https://biomejs.dev/schemas/2.4.10/schema.json",
	"files": {
		"includes": [
			"src/**",
			"src-tauri/plugins/**/guest-js/**",
			"*.ts",
			"*.json",
			"!src-tauri/target",
			"!src-tauri/gen",
			"!.claude",
			"!dist",
			"!node_modules"
		]
	},
	"assist": {
		"actions": {
			"source": {
				"organizeImports": "on"
			}
		}
	},
	"linter": {
		"enabled": true,
		"rules": {
			"recommended": true,
			"suspicious": {
				"noExplicitAny": "error"
			}
		}
	},
	"formatter": {
		"enabled": true,
		"indentStyle": "tab"
	}
}
