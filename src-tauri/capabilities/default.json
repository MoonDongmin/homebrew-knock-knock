{
	"identifier": "default",
	"description": "Default capability for KnockKnock",
	"windows": ["main"],
	"permissions": [
		"core:default",
		"core:event:default",
		"store:default",
		"shell:default",
		{
			"identifier": "shell:allow-execute",
			"allow": [
				{
					"name": "exec-sh",
					"cmd": "sh",
					"args": ["-c", { "validator": ".*" }]
				}
			]
		},
		"accelerometer:default",
		"dialog:default"
	]
}
